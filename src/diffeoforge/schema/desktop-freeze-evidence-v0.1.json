{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diffeoforge.org/schema/desktop-freeze-evidence-v0.1.json",
  "title": "DiffeoForge desktop freeze evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "created_at",
    "target",
    "source",
    "builder",
    "runtime_packages",
    "entry_points",
    "bundle",
    "missing_release_gates",
    "scientific_boundary"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "status": { "const": "engineering_evidence_not_a_release" },
    "created_at": { "type": "string", "format": "date-time" },
    "target": { "const": "windows-x86_64-cpu" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit_sha", "dirty_worktree_allowed"],
      "properties": {
        "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "dirty_worktree_allowed": { "const": false }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "mode", "python", "platform"],
      "properties": {
        "name": { "const": "PyInstaller" },
        "version": { "type": "string", "minLength": 1 },
        "mode": { "const": "onedir" },
        "python": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 }
      }
    },
    "runtime_packages": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 },
      "required": [
        "diffeoforge",
        "numpy",
        "psutil",
        "pyinstaller",
        "pyside6-essentials",
        "shiboken6",
        "torch"
      ]
    },
    "entry_points": {
      "type": "object",
      "additionalProperties": false,
      "required": ["desktop", "worker"],
      "properties": {
        "desktop": { "const": "DiffeoForge.exe" },
        "worker": { "const": "DiffeoForgeWorker.exe" }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory_name",
        "file_count",
        "total_bytes",
        "inventory_sha256",
        "files"
      ],
      "properties": {
        "directory_name": { "type": "string", "minLength": 1 },
        "file_count": { "type": "integer", "minimum": 2 },
        "total_bytes": { "type": "integer", "minimum": 1 },
        "inventory_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "files": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes", "sha256"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
              },
              "bytes": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        }
      }
    },
    "missing_release_gates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "authenticode_signature",
          "clean_windows_vm",
          "cpu_numerical_release_validation",
          "crash_reconciliation",
          "installer_and_uninstaller",
          "license_inventory",
          "no_network_observation",
          "sbom",
          "windows_defender_scan"
        ]
      }
    },
    "scientific_boundary": { "type": "string", "minLength": 1 }
  }
}
