{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiffeoForge completed optimizer benchmark study run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "optimizer_study_run_version", "status", "completed_at", "design",
    "source_config", "conditions", "analysis_performed", "scientific_boundary"
  ],
  "$defs": {
    "bound_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  },
  "properties": {
    "optimizer_study_run_version": {"const": "0.1"},
    "status": {"const": "complete"},
    "completed_at": {"type": "string", "minLength": 1},
    "design": {"$ref": "#/$defs/bound_file"},
    "source_config": {"$ref": "#/$defs/bound_file"},
    "conditions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sequence", "condition_id", "subject_count", "cycle_cap",
          "report_directory", "artifacts"
        ],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1, "maximum": 1000},
          "condition_id": {
            "type": "string",
            "pattern": "^condition-[0-9]{4}-subjects-[0-9]{4}-cycles-[0-9]{3}$"
          },
          "subject_count": {"type": "integer", "minimum": 1, "maximum": 1000},
          "cycle_cap": {"type": "integer", "minimum": 1, "maximum": 100},
          "report_directory": {
            "type": "string",
            "pattern": "^conditions/condition-[0-9]{4}-subjects-[0-9]{4}-cycles-[0-9]{3}$"
          },
          "artifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": ["optimizer-benchmark.json", "samples.csv", "optimizer-benchmark.html"],
            "properties": {
              "optimizer-benchmark.json": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "samples.csv": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "optimizer-benchmark.html": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    },
    "analysis_performed": {"const": false},
    "scientific_boundary": {
      "const": "This run preserves every separate raw multi-cycle optimizer benchmark in its frozen subject-by-cycle order. It performs no automatic comparison, winner selection, ETA model, convergence assessment, scaling extrapolation, Deformetrica comparison, safe-preset selection, or 300-subject feasibility test."
    }
  }
}
