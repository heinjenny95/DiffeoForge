{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiffeoForge prospective optimizer scaling design",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "optimizer_design_version", "design_id", "created_at", "software",
    "source_config", "input", "configuration", "protocol", "conditions",
    "scientific_boundary"
  ],
  "$defs": {
    "mesh": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "role", "bytes", "sha256", "points", "triangles"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "role": {"enum": ["template", "subject"]},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "points": {"type": "integer", "minimum": 1},
        "triangles": {"type": "integer", "minimum": 1}
      }
    },
    "pairwise_plan": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "query_tile_size", "source_tile_size"],
          "properties": {
            "mode": {"const": "dense"},
            "query_tile_size": {"type": "null"},
            "source_tile_size": {"type": "null"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "query_tile_size", "source_tile_size"],
          "properties": {
            "mode": {"const": "blockwise"},
            "query_tile_size": {"type": "integer", "minimum": 1},
            "source_tile_size": {"type": "integer", "minimum": 1}
          }
        }
      ]
    }
  },
  "properties": {
    "optimizer_design_version": {"const": "0.1"},
    "design_id": {"const": "full_factorial_subject_cycle"},
    "created_at": {"type": "string", "minLength": 1},
    "software": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diffeoforge", "optimizer_benchmark_version"],
      "properties": {
        "diffeoforge": {"type": "string", "minLength": 1},
        "optimizer_benchmark_version": {"const": "0.1"}
      }
    },
    "source_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "sha256", "project"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "project": {"type": "string", "minLength": 1}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template", "subjects", "available_subject_count", "selection"],
      "properties": {
        "template": {"$ref": "#/$defs/mesh"},
        "subjects": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/mesh"}},
        "available_subject_count": {"type": "integer", "minimum": 1},
        "selection": {"const": "first subjects in validated deterministic path order"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_points", "timepoints", "attachment_type", "shooting_integrator",
        "flow_integrator", "pairwise_evaluation", "source_max_cycles", "block_order",
        "momenta_step_size", "template_step_size", "control_points_step_size",
        "backtracking_factor", "armijo_constant", "gradient_tolerance",
        "minimum_step_size", "max_line_search_iterations", "threads", "random_seed"
      ],
      "properties": {
        "control_points": {"type": "integer", "minimum": 1},
        "timepoints": {"type": "integer", "minimum": 2},
        "attachment_type": {"enum": ["current", "varifold"]},
        "shooting_integrator": {"enum": ["euler", "rk2"]},
        "flow_integrator": {"enum": ["euler", "heun", "deformetrica_heun"]},
        "pairwise_evaluation": {"$ref": "#/$defs/pairwise_plan"},
        "source_max_cycles": {"type": "integer", "minimum": 0},
        "block_order": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {"enum": ["momenta", "template", "control_points"]}
        },
        "momenta_step_size": {"type": "number", "exclusiveMinimum": 0},
        "template_step_size": {"type": "number", "exclusiveMinimum": 0},
        "control_points_step_size": {"type": "number", "exclusiveMinimum": 0},
        "backtracking_factor": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1},
        "armijo_constant": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1},
        "gradient_tolerance": {"type": "number", "minimum": 0},
        "minimum_step_size": {"type": "number", "exclusiveMinimum": 0},
        "max_line_search_iterations": {"type": "integer", "minimum": 1},
        "threads": {"type": "integer", "minimum": 1},
        "random_seed": {"type": "integer", "minimum": 0}
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frozen_before_results", "subject_counts", "cycle_caps", "condition_count",
        "maximum_condition_count", "repeats_per_condition", "warmup_runs_per_repeat",
        "order_seed", "order_algorithm", "analysis_policy"
      ],
      "properties": {
        "frozen_before_results": {"const": true},
        "subject_counts": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1, "maximum": 1000}
        },
        "cycle_caps": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1, "maximum": 100}
        },
        "condition_count": {"type": "integer", "minimum": 1, "maximum": 1000},
        "maximum_condition_count": {"const": 1000},
        "repeats_per_condition": {"type": "integer", "minimum": 1, "maximum": 50},
        "warmup_runs_per_repeat": {"type": "integer", "minimum": 0, "maximum": 10},
        "order_seed": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "order_algorithm": {"const": "sha256-ranked-subject-cycle-cells-v0.1"},
        "analysis_policy": {
          "const": "Preserve every separate raw optimizer report; report descriptive time, sampled RSS, work counts, termination, and repeat consistency without selecting a preferred condition, fitting an ETA model, extrapolating beyond observed cells, or claiming convergence."
        }
      }
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sequence", "condition_id", "cell_id", "subject_count", "cycle_cap",
          "output_directory", "argv"
        ],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1, "maximum": 1000},
          "condition_id": {
            "type": "string",
            "pattern": "^condition-[0-9]{4}-subjects-[0-9]{4}-cycles-[0-9]{3}$"
          },
          "cell_id": {"type": "string", "pattern": "^subjects-[0-9]{4}-cycles-[0-9]{3}$"},
          "subject_count": {"type": "integer", "minimum": 1, "maximum": 1000},
          "cycle_cap": {"type": "integer", "minimum": 1, "maximum": 100},
          "output_directory": {
            "type": "string",
            "pattern": "^conditions/condition-[0-9]{4}-subjects-[0-9]{4}-cycles-[0-9]{3}$"
          },
          "argv": {
            "type": "array", "minItems": 13, "maxItems": 13,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "scientific_boundary": {
      "const": "This artifact freezes a full-factorial subject-prefix and optimizer-cycle benchmark design before results exist. It performs no optimization, timing, memory sampling, convergence assessment, ETA fitting, Deformetrica comparison, or 300-subject feasibility test."
    }
  }
}
