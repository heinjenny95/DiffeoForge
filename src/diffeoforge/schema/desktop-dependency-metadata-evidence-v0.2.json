{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diffeoforge.org/schema/desktop-dependency-metadata-evidence-v0.2.json",
  "title": "DiffeoForge desktop dependency metadata evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "target",
    "source",
    "generator",
    "package_count",
    "package_set_sha256",
    "packages",
    "review_boundary",
    "missing_release_gates",
    "scientific_boundary"
  ],
  "properties": {
    "schema_version": { "const": "0.2" },
    "status": {
      "const": "distribution_metadata_inventory_not_license_or_redistribution_approval"
    },
    "target": { "const": "windows-x86_64-cpu" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freeze_evidence_schema_version",
        "freeze_evidence_sha256",
        "source_commit_sha",
        "bundle_inventory_sha256"
      ],
      "properties": {
        "freeze_evidence_schema_version": { "const": "0.4" },
        "freeze_evidence_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_commit_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "bundle_inventory_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diffeoforge", "python"],
      "properties": {
        "diffeoforge": { "type": "string", "minLength": 1 },
        "python": { "type": "string", "minLength": 1 }
      }
    },
    "package_count": { "type": "integer", "minimum": 1 },
    "package_set_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/package" }
    },
    "review_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["license_compatibility", "redistribution", "sbom"],
      "properties": {
        "license_compatibility": { "const": "not_reviewed" },
        "redistribution": { "const": "not_reviewed" },
        "sbom": { "const": "not_an_sbom" }
      }
    },
    "missing_release_gates": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "license_inventory",
          "license_compatibility_review",
          "redistribution_approval",
          "sbom"
        ]
      }
    },
    "scientific_boundary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "metadata",
        "license_files",
        "unresolved_declared_license_files",
        "observations",
        "review_status"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "version": { "type": "string", "minLength": 1 },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "metadata_version",
            "name",
            "version",
            "bytes",
            "sha256",
            "license_expression",
            "license_field",
            "license_classifiers",
            "license_files_declared",
            "requires_dist"
          ],
          "properties": {
            "metadata_version": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "bytes": { "type": "integer", "minimum": 1 },
            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "license_expression": { "type": ["string", "null"] },
            "license_field": { "type": ["string", "null"] },
            "license_classifiers": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "license_files_declared": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            },
            "requires_dist": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "license_files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "bytes", "sha256", "source"],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
              },
              "bytes": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "source": { "enum": ["declared", "discovered"] }
            }
          }
        },
        "unresolved_declared_license_files": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "observations": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "declared_license_file_not_installed",
              "declared_license_files_absent",
              "legacy_license_field_present",
              "license_and_expression_both_present",
              "license_classifiers_present",
              "license_expression_absent",
              "license_file_candidates_absent"
            ]
          }
        },
        "review_status": { "const": "unreviewed" }
      }
    }
  }
}
