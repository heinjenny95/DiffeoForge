{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diffeoforge.org/schema/resume-v0.1.json",
  "title": "DiffeoForge resume provenance 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resume_version",
    "created_at",
    "source_run",
    "source_manifest",
    "source_result",
    "source_output_inventory",
    "checkpoint",
    "semantics"
  ],
  "properties": {
    "resume_version": {"const": "0.1"},
    "created_at": {"type": "string", "format": "date-time"},
    "source_run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "path", "terminal_status"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "terminal_status": {"enum": ["failed", "interrupted"]}
      }
    },
    "source_manifest": {"$ref": "#/$defs/evidence"},
    "source_result": {"$ref": "#/$defs/evidence"},
    "source_output_inventory": {"$ref": "#/$defs/evidence"},
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "staged_path", "execution_path", "bytes", "sha256"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "staged_path": {"const": "resume/source-checkpoint.p"},
        "execution_path": {"const": "output/deformetrica-state.p"},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend_id",
        "backend_version",
        "restored",
        "reinitialized",
        "trajectory_continuity"
      ],
      "properties": {
        "backend_id": {"const": "deformetrica_reference"},
        "backend_version": {"const": "4.3.0"},
        "restored": {"const": ["current_parameters", "current_iteration"]},
        "reinitialized": {
          "const": ["objective_baseline", "gradient", "line_search_step_sizes"]
        },
        "trajectory_continuity": {"const": "not_guaranteed"}
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
