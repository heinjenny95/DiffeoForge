{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diffeoforge.org/schema/reference-preparation-plan-v0.1.json",
  "title": "DiffeoForge read-only reference preparation plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "source_config",
    "run",
    "backend",
    "planner",
    "directories",
    "input_count",
    "inputs",
    "effective_config",
    "protected_files",
    "protected_file_count",
    "total_protected_bytes",
    "command_preview",
    "scientific_boundary"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "status": { "const": "read_only_plan_not_prepared" },
    "source_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "output_root", "destination", "destination_exists"],
      "properties": {
        "run_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
        "output_root": { "type": "string", "minLength": 1 },
        "destination": { "type": "string", "minLength": 1 },
        "destination_exists": { "const": false }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "contract_version", "engine_constants"],
      "properties": {
        "id": { "const": "deformetrica_reference" },
        "contract_version": { "const": "0.1" },
        "engine_constants": {
          "type": "object",
          "additionalProperties": false,
          "required": ["line_search_shrink", "line_search_expand", "state_file"],
          "properties": {
            "line_search_shrink": { "const": 0.5 },
            "line_search_expand": { "const": 1.5 },
            "state_file": { "const": "output/deformetrica-state.p" }
          }
        }
      }
    },
    "planner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diffeoforge", "python", "platform", "native_newline"],
      "properties": {
        "diffeoforge": { "type": "string", "minLength": 1 },
        "python": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "native_newline": { "enum": ["LF", "CRLF"] }
      }
    },
    "directories": {
      "const": [
        "config",
        "engine",
        "input/template",
        "input/subjects",
        "logs",
        "output"
      ]
    },
    "input_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templates", "subjects"],
      "properties": {
        "templates": { "const": 1 },
        "subjects": { "type": "integer", "minimum": 2 }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/input" }
    },
    "effective_config": {
      "type": "object",
      "required": [
        "schema_version",
        "project",
        "input",
        "model",
        "optimization",
        "runtime",
        "output"
      ]
    },
    "protected_files": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/protected_file" }
    },
    "protected_file_count": { "type": "integer", "minimum": 8 },
    "total_protected_bytes": { "type": "integer", "minimum": 1 },
    "command_preview": { "$ref": "#/$defs/command" },
    "scientific_boundary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "geometry": {
      "type": "object",
      "required": [
        "bytes",
        "sha256",
        "vtk_version",
        "encoding",
        "dataset_type",
        "points",
        "cells",
        "triangular",
        "bounds",
        "bounding_box_extents",
        "bounding_box_diagonal"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "source_path", "staged_path", "geometry"],
      "properties": {
        "role": { "enum": ["template", "subject"] },
        "source_path": { "type": "string", "minLength": 1 },
        "staged_path": { "type": "string", "minLength": 1 },
        "geometry": { "$ref": "#/$defs/geometry" }
      }
    },
    "protected_file": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path", "source_path", "bytes", "sha256"],
          "properties": {
            "kind": { "const": "copied" },
            "path": { "type": "string", "minLength": 1 },
            "source_path": { "type": "string", "minLength": 1 },
            "bytes": { "type": "integer", "minimum": 1 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "path", "bytes", "sha256", "content_utf8"],
          "properties": {
            "kind": { "const": "generated" },
            "path": { "type": "string", "minLength": 1 },
            "bytes": { "type": "integer", "minimum": 1 },
            "sha256": { "$ref": "#/$defs/sha256" },
            "content_utf8": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv", "working_directory", "environment"],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "working_directory": { "type": "string", "minLength": 1 },
        "environment": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
