{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiffeoForge modern atlas result bundle",
  "description": "Immutable experimental modern-engine atlas outputs and PCA handoff.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "created_at",
    "engine",
    "model",
    "optimizer",
    "template",
    "parameters",
    "subjects",
    "pca",
    "quality",
    "artifacts",
    "scientific_boundary",
    "immutability_contract"
  ],
  "properties": {
    "bundle_version": {"const": "0.1"},
    "created_at": {"type": "string", "minLength": 1},
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "diffeoforge", "pytorch", "numpy", "device", "dtype"],
      "properties": {
        "id": {"enum": ["diffeoforge_modern_dense", "diffeoforge_modern_blockwise"]},
        "diffeoforge": {"type": "string", "minLength": 1},
        "pytorch": {"type": "string", "minLength": 1},
        "numpy": {"type": "string", "minLength": 1},
        "device": {"const": "cpu"},
        "dtype": {"const": "float64"},
        "pairwise_evaluation": {"$ref": "#/$defs/pairwiseEvaluation"}
      },
      "allOf": [
        {
          "if": {
            "required": ["pairwise_evaluation"],
            "properties": {
              "pairwise_evaluation": {
                "properties": {"mode": {"const": "blockwise"}}
              }
            }
          },
          "then": {
            "properties": {"id": {"const": "diffeoforge_modern_blockwise"}}
          }
        },
        {
          "if": {
            "required": ["pairwise_evaluation"],
            "properties": {
              "pairwise_evaluation": {
                "properties": {"mode": {"const": "dense"}}
              }
            }
          },
          "then": {
            "properties": {"id": {"const": "diffeoforge_modern_dense"}}
          }
        }
      ]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deformation_kernel_width",
        "attachment_kernel_width",
        "noise_variance",
        "number_of_time_points",
        "attachment_type",
        "shooting_integrator",
        "flow_integrator"
      ],
      "properties": {
        "deformation_kernel_width": {"type": "number", "exclusiveMinimum": 0},
        "attachment_kernel_width": {"type": "number", "exclusiveMinimum": 0},
        "noise_variance": {"type": "number", "exclusiveMinimum": 0},
        "number_of_time_points": {"type": "integer", "minimum": 2},
        "attachment_type": {"enum": ["current", "varifold"]},
        "shooting_integrator": {"enum": ["euler", "rk2"]},
        "flow_integrator": {"enum": ["euler", "heun", "deformetrica_heun"]}
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settings", "termination_reason", "converged", "failed_block", "cycles_completed", "total_line_search_evaluations", "history_path", "final_objective", "final_attachment", "final_regularity"],
      "properties": {
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_cycles", "block_order", "momenta_step_size", "template_step_size", "control_points_step_size", "backtracking_factor", "armijo_constant", "gradient_tolerance", "minimum_step_size", "max_line_search_iterations"],
          "properties": {
            "max_cycles": {"type": "integer", "minimum": 0},
            "block_order": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "uniqueItems": true,
              "items": {"enum": ["momenta", "template", "control_points"]}
            },
            "momenta_step_size": {"type": "number", "exclusiveMinimum": 0},
            "template_step_size": {"type": "number", "exclusiveMinimum": 0},
            "control_points_step_size": {"type": "number", "exclusiveMinimum": 0},
            "backtracking_factor": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1},
            "armijo_constant": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1},
            "gradient_tolerance": {"type": "number", "minimum": 0},
            "minimum_step_size": {"type": "number", "exclusiveMinimum": 0},
            "max_line_search_iterations": {"type": "integer", "minimum": 1}
          }
        },
        "termination_reason": {"enum": ["gradient_tolerance", "max_cycles", "line_search_failed"]},
        "converged": {"type": "boolean"},
        "failed_block": {"enum": ["momenta", "template", "control_points", null]},
        "cycles_completed": {"type": "integer", "minimum": 0},
        "total_line_search_evaluations": {"type": "integer", "minimum": 0},
        "history_path": {"type": "string", "minLength": 1},
        "final_objective": {"type": "number"},
        "final_attachment": {"type": "number"},
        "final_regularity": {"type": "number"}
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "points", "triangles"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "points": {"type": "integer", "minimum": 1},
        "triangles": {"type": "integer", "minimum": 1}
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_points_path", "momenta_path", "control_points", "subjects", "dimensions"],
      "properties": {
        "control_points_path": {"type": "string", "minLength": 1},
        "momenta_path": {"type": "string", "minLength": 1},
        "control_points": {"type": "integer", "minimum": 1},
        "subjects": {"type": "integer", "minimum": 2},
        "dimensions": {"const": 3}
      }
    },
    "subjects": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "label", "reconstruction_path", "residual"],
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "label": {"type": "string", "minLength": 1},
          "reconstruction_path": {"type": "string", "minLength": 1},
          "residual": {"type": "number", "minimum": 0}
        }
      }
    },
    "pca": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_space", "components", "numerical_rank", "total_variance", "summary_path", "scores_path", "loadings_path", "mean_path", "plots", "deformations"],
      "properties": {
        "feature_space": {"const": "subject_initial_momenta_cartesian"},
        "components": {"type": "integer", "minimum": 1},
        "numerical_rank": {"type": "integer", "minimum": 1},
        "total_variance": {"type": "number", "exclusiveMinimum": 0},
        "summary_path": {"type": "string", "minLength": 1},
        "scores_path": {"type": "string", "minLength": 1},
        "loadings_path": {"type": "string", "minLength": 1},
        "mean_path": {"type": "string", "minLength": 1},
        "plots": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scree_path", "scores_path", "score_axes"],
          "properties": {
            "scree_path": {"type": "string", "minLength": 1},
            "scores_path": {"type": "string", "minLength": 1},
            "score_axes": {
              "oneOf": [
                {"const": ["PC1"]},
                {"const": ["PC1", "PC2"]}
              ]
            },
            "scores_pc2_pc3_path": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {"type": "null"}
              ]
            },
            "scores_pc2_pc3_axes": {
              "oneOf": [
                {"const": ["PC2", "PC3"]},
                {"type": "null"}
              ]
            },
            "scores_pc2_pc3_unavailable_reason": {
              "oneOf": [
                {"type": "string", "minLength": 1},
                {"type": "null"}
              ]
            }
          }
        },
        "deformations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["definition_path", "feature_space", "feature_order", "sign_convention", "equation", "standard_deviations", "requested_components", "mean_path", "components", "skipped_zero_variance_components", "interpretation_boundary"],
          "properties": {
            "definition_path": {"type": "string", "minLength": 1},
            "feature_space": {"const": "subject_initial_momenta_cartesian"},
            "feature_order": {"const": "control point index outer; Cartesian x, y, z inner"},
            "sign_convention": {"type": "string", "minLength": 1},
            "equation": {"const": "mean_momenta +/- standard_deviations * sqrt(explained_variance) * component_loading"},
            "standard_deviations": {"type": "number", "exclusiveMinimum": 0},
            "requested_components": {"type": "integer", "minimum": 1},
            "mean_path": {"type": "string", "minLength": 1},
            "components": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["component", "label", "explained_variance", "explained_variance_ratio", "momenta_standard_deviation", "minus_path", "plus_path"],
                "properties": {
                  "component": {"type": "integer", "minimum": 1},
                  "label": {"type": "string", "pattern": "^PC[1-9][0-9]*$"},
                  "explained_variance": {"type": "number", "exclusiveMinimum": 0},
                  "explained_variance_ratio": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
                  "momenta_standard_deviation": {"type": "number", "exclusiveMinimum": 0},
                  "minus_path": {"type": "string", "minLength": 1},
                  "plus_path": {"type": "string", "minLength": 1}
                }
              }
            },
            "skipped_zero_variance_components": {
              "type": "array",
              "uniqueItems": true,
              "items": {"type": "integer", "minimum": 1}
            },
            "interpretation_boundary": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_path", "csv_path", "settings", "reference_path", "assessed_meshes", "scientific_boundary"],
      "properties": {
        "report_path": {"type": "string", "minLength": 1},
        "csv_path": {"type": "string", "minLength": 1},
        "settings": {"$ref": "#/$defs/qualitySettings"},
        "reference_path": {"type": "string", "minLength": 1},
        "assessed_meshes": {"type": "integer", "minimum": 1},
        "scientific_boundary": {"type": "string", "minLength": 1}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 10,
      "items": {"$ref": "#/$defs/artifact"}
    },
    "scientific_boundary": {"type": "string", "minLength": 1},
    "immutability_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creation", "manifest", "artifacts", "extra_files", "signature"],
      "properties": {
        "creation": {"const": "atomic rename into a previously nonexistent destination"},
        "manifest": {"const": "SHA-256 sidecar"},
        "artifacts": {"const": "all listed files require matching byte size and SHA-256"},
        "extra_files": {"const": "verification failure"},
        "signature": {"const": "not cryptographically signed"}
      }
    }
  },
  "$defs": {
    "pairwiseEvaluation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "query_tile_size", "source_tile_size"],
          "properties": {
            "mode": {"const": "dense"},
            "query_tile_size": {"type": "null"},
            "source_tile_size": {"type": "null"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "query_tile_size", "source_tile_size"],
          "properties": {
            "mode": {"const": "blockwise"},
            "query_tile_size": {"type": "integer", "minimum": 1},
            "source_tile_size": {"type": "integer", "minimum": 1}
          }
        }
      ]
    },
    "qualitySettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_no_duplicate_faces", "require_no_isolated_vertices",
        "require_edge_manifold", "require_consistent_orientation",
        "require_single_component", "require_closed_surface",
        "reject_zero_area_faces", "minimum_triangle_angle_degrees",
        "maximum_triangle_edge_ratio", "minimum_face_area_ratio",
        "maximum_face_area_ratio"
      ],
      "properties": {
        "require_no_duplicate_faces": {"type": "boolean"},
        "require_no_isolated_vertices": {"type": "boolean"},
        "require_edge_manifold": {"type": "boolean"},
        "require_consistent_orientation": {"type": "boolean"},
        "require_single_component": {"type": "boolean"},
        "require_closed_surface": {"type": "boolean"},
        "reject_zero_area_faces": {"type": "boolean"},
        "minimum_triangle_angle_degrees": {"type": ["number", "null"], "exclusiveMinimum": 0, "maximum": 60},
        "maximum_triangle_edge_ratio": {"type": ["number", "null"], "minimum": 1},
        "minimum_face_area_ratio": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "maximum_face_area_ratio": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
