{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diffeoforge.org/schema/reference-preparation-approval-verification-v0.1.json",
  "title": "DiffeoForge reference preparation approval verification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "verifier",
    "request",
    "approval",
    "recorded_plan",
    "current_state",
    "checks",
    "scientific_boundary"
  ],
  "properties": {
    "schema_version": { "const": "0.1" },
    "status": { "const": "verified_reference_preparation_approval" },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diffeoforge"],
      "properties": { "diffeoforge": { "type": "string", "minLength": 1 } }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 2 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "approved_plan_fingerprint", "engine_execution_authorized"],
      "properties": {
        "scope": { "const": "preparation_only" },
        "approved_plan_fingerprint": { "$ref": "#/$defs/sha256" },
        "engine_execution_authorized": { "const": false }
      }
    },
    "recorded_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "destination",
        "subjects",
        "protected_files",
        "total_protected_bytes"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "destination": { "type": "string", "minLength": 1 },
        "subjects": { "type": "integer", "minimum": 2 },
        "protected_files": { "type": "integer", "minimum": 8 },
        "total_protected_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "current_state": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "config_path",
            "plan_fingerprint",
            "matches_approved_plan",
            "destination_absent"
          ],
          "properties": {
            "config_path": { "type": "string", "minLength": 1 },
            "plan_fingerprint": { "$ref": "#/$defs/sha256" },
            "matches_approved_plan": { "const": true },
            "destination_absent": { "const": true }
          }
        }
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "enum": [
          "request_strict_utf8_single_json_document",
          "request_unique_object_keys_and_finite_constants",
          "request_schema_valid",
          "embedded_plan_schema_valid",
          "embedded_plan_matches_approved_fingerprint",
          "preparation_only_scope_and_no_engine_authorization",
          "fresh_current_plan_matches_approved_plan",
          "request_unchanged_during_verification"
        ]
      }
    },
    "scientific_boundary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
