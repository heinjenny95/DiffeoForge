{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiffeoForge matrix benchmark study progress event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "progress_version",
    "sequence",
    "status",
    "message",
    "completed_conditions",
    "total_conditions",
    "condition"
  ],
  "properties": {
    "progress_version": {"const": "0.2"},
    "sequence": {"type": "integer", "minimum": 0},
    "status": {
      "enum": [
        "study_started",
        "study_resumed",
        "condition_started",
        "condition_completed",
        "condition_reconciled",
        "study_interrupted",
        "study_completed",
        "study_already_complete"
      ]
    },
    "message": {"type": "string", "minLength": 1},
    "completed_conditions": {"type": "integer", "minimum": 0},
    "total_conditions": {"type": "integer", "minimum": 1},
    "condition": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sequence",
            "condition_id",
            "cell_id",
            "subject_count",
            "effective_pairwise_evaluation",
            "tile_autograd_strategy"
          ],
          "properties": {
            "sequence": {"type": "integer", "minimum": 1, "maximum": 1000},
            "condition_id": {
              "type": "string",
              "pattern": "^condition-[0-9]{4}-subjects-[0-9]{6}-tiles-q[0-9]{6}-s[0-9]{6}-(standard|recompute)$"
            },
            "cell_id": {
              "type": "string",
              "pattern": "^subjects-[0-9]{6}-tiles-q[0-9]{6}-s[0-9]{6}$"
            },
            "subject_count": {"type": "integer", "minimum": 1, "maximum": 100000},
            "effective_pairwise_evaluation": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "query_tile_size", "source_tile_size"],
              "properties": {
                "mode": {"const": "blockwise"},
                "query_tile_size": {"type": "integer", "minimum": 1, "maximum": 999999},
                "source_tile_size": {"type": "integer", "minimum": 1, "maximum": 999999}
              }
            },
            "tile_autograd_strategy": {"enum": ["standard", "recompute"]}
          }
        }
      ]
    }
  }
}
