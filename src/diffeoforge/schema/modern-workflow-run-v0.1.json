{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiffeoForge immutable modern workflow run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_version",
    "created_at",
    "project",
    "engine",
    "config",
    "input",
    "preprocessing",
    "quality",
    "initialization",
    "result_bundle",
    "artifacts",
    "scientific_boundary",
    "immutability_contract"
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "mesh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index", "label", "source_filename", "raw_path", "aligned_path",
        "bytes", "sha256", "points", "triangles"
      ],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "label": {"type": "string", "minLength": 1},
        "source_filename": {"type": "string", "minLength": 1},
        "raw_path": {"type": "string", "minLength": 1},
        "aligned_path": {
          "oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]
        },
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "points": {"type": "integer", "minimum": 1},
        "triangles": {"type": "integer", "minimum": 1}
      }
    },
    "qualitySettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_no_duplicate_faces", "require_no_isolated_vertices",
        "require_edge_manifold", "require_consistent_orientation",
        "require_single_component", "require_closed_surface",
        "reject_zero_area_faces", "minimum_triangle_angle_degrees",
        "maximum_triangle_edge_ratio", "minimum_face_area_ratio",
        "maximum_face_area_ratio"
      ],
      "properties": {
        "require_no_duplicate_faces": {"type": "boolean"},
        "require_no_isolated_vertices": {"type": "boolean"},
        "require_edge_manifold": {"type": "boolean"},
        "require_consistent_orientation": {"type": "boolean"},
        "require_single_component": {"type": "boolean"},
        "require_closed_surface": {"type": "boolean"},
        "reject_zero_area_faces": {"type": "boolean"},
        "minimum_triangle_angle_degrees": {"type": ["number", "null"], "exclusiveMinimum": 0, "maximum": 60},
        "maximum_triangle_edge_ratio": {"type": ["number", "null"], "minimum": 1},
        "minimum_face_area_ratio": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "maximum_face_area_ratio": {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },
    "pairwiseEvaluation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "query_tile_size", "source_tile_size"],
          "properties": {
            "mode": {"const": "dense"},
            "query_tile_size": {"type": "null"},
            "source_tile_size": {"type": "null"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "query_tile_size", "source_tile_size"],
          "properties": {
            "mode": {"const": "blockwise"},
            "query_tile_size": {"type": "integer", "minimum": 1},
            "source_tile_size": {"type": "integer", "minimum": 1}
          }
        }
      ]
    }
  },
  "properties": {
    "workflow_version": {"const": "0.1"},
    "created_at": {"type": "string", "minLength": 1},
    "project": {"type": "object", "additionalProperties": false, "required": ["name"], "properties": {"name": {"type": "string", "minLength": 1}}},
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "diffeoforge", "pytorch", "numpy", "device", "dtype", "threads", "random_seed"],
      "properties": {
        "id": {"enum": ["diffeoforge_modern_dense", "diffeoforge_modern_blockwise"]},
        "diffeoforge": {"type": "string", "minLength": 1},
        "pytorch": {"type": "string", "minLength": 1},
        "numpy": {"type": "string", "minLength": 1},
        "device": {"const": "cpu"},
        "dtype": {"const": "float64"},
        "threads": {"type": "integer", "minimum": 1},
        "random_seed": {"type": "integer", "minimum": 0},
        "pairwise_evaluation": {"$ref": "#/$defs/pairwiseEvaluation"}
      },
      "allOf": [
        {
          "if": {
            "required": ["pairwise_evaluation"],
            "properties": {
              "pairwise_evaluation": {
                "properties": {"mode": {"const": "blockwise"}}
              }
            }
          },
          "then": {
            "properties": {"id": {"const": "diffeoforge_modern_blockwise"}}
          }
        },
        {
          "if": {
            "required": ["pairwise_evaluation"],
            "properties": {
              "pairwise_evaluation": {
                "properties": {"mode": {"const": "dense"}}
              }
            }
          },
          "then": {
            "properties": {"id": {"const": "diffeoforge_modern_dense"}}
          }
        }
      ]
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "effective_path"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "effective_path": {"type": "string", "minLength": 1}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["units", "subject_pattern", "template", "subjects"],
      "properties": {
        "units": {"type": "string", "minLength": 1},
        "subject_pattern": {"type": "string", "minLength": 1},
        "template": {"$ref": "#/$defs/mesh"},
        "subjects": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/mesh"}}
      }
    },
    "preprocessing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "landmarks_path", "alignment_path", "converged", "termination_reason"],
      "properties": {
        "id": {"enum": ["none", "generalized_procrustes"]},
        "landmarks_path": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
        "alignment_path": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
        "converged": {"oneOf": [{"type": "boolean"}, {"type": "null"}]},
        "termination_reason": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_path", "csv_path", "settings", "assessed_meshes", "scientific_boundary"],
      "properties": {
        "report_path": {"type": "string", "minLength": 1},
        "csv_path": {"type": "string", "minLength": 1},
        "settings": {"$ref": "#/$defs/qualitySettings"},
        "assessed_meshes": {"type": "integer", "minimum": 2},
        "scientific_boundary": {"type": "string", "minLength": 1}
      }
    },
    "initialization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_points", "momenta"],
      "properties": {
        "control_points": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "count", "template_vertex_indices"],
          "properties": {
            "method": {"const": "farthest_template_vertices"},
            "count": {"type": "integer", "minimum": 1},
            "template_vertex_indices": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}}
          }
        },
        "momenta": {"const": "zeros"}
      }
    },
    "result_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bundle_version", "manifest_sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bundle_version": {"const": "0.1"},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}},
    "scientific_boundary": {"type": "string", "minLength": 1},
    "immutability_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creation", "manifest", "artifacts", "extra_files", "signature"],
      "properties": {
        "creation": {"type": "string", "minLength": 1},
        "manifest": {"type": "string", "minLength": 1},
        "artifacts": {"type": "string", "minLength": 1},
        "extra_files": {"type": "string", "minLength": 1},
        "signature": {"type": "string", "minLength": 1}
      }
    }
  }
}
