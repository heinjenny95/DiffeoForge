{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiffeoForge private unpublished run marker",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "marker_version",
    "kind",
    "safety_status",
    "operation",
    "destination",
    "private_directory",
    "run_token",
    "pid",
    "created_at",
    "diffeoforge_version",
    "lease_file"
  ],
  "properties": {
    "marker_version": {"const": "0.1"},
    "kind": {"const": "diffeoforge_private_run"},
    "safety_status": {"const": "private_unpublished_not_a_result"},
    "operation": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$"},
    "destination": {"type": "string", "minLength": 1},
    "private_directory": {"type": "string", "minLength": 1},
    "run_token": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "pid": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "diffeoforge_version": {"type": "string", "minLength": 1},
    "lease_file": {"const": ".diffeoforge-private-run.lock"}
  }
}
